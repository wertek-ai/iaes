{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iaes.wertek.ai/schema/v1/maintenance.work_order_intent",
  "title": "IAES maintenance.work_order_intent",
  "description": "Declares the intent to create a maintenance work order. The consumer decides whether and how to act.",
  "allOf": [
    { "$ref": "iaes-envelope.schema.json" }
  ],
  "properties": {
    "event_type": { "const": "maintenance.work_order_intent" },
    "data": {
      "type": "object",
      "required": ["title", "priority"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Work order title"
        },
        "description": {
          "type": ["string", "null"],
          "description": "Detailed work description"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high", "emergency"],
          "description": "Suggested priority level"
        },
        "recommended_due_days": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Suggested deadline in days from now"
        },
        "triggered_by": {
          "type": ["string", "null"],
          "enum": ["alert", "schedule", "manual", "threshold", "ai_diagnosis", null],
          "description": "What caused this work order intent"
        }
      }
    }
  }
}
